#!/usr/bin/env perl

use warnings;
use strict;
use Data::Dumper;
use Getopt::Long;
use Carp;
use TPSUP::AUTOSYS qw(get_dependency query_jobs);
use TPSUP::UTIL    qw(get_in_fh);
# use Carp::Always;

my $prog = $0; $prog =~ s:.*/::;

my $DetailExpire = 300;
my $StatusExpire = 1;

sub usage {
   my ($message) = @_;
   print "$message\n" if $message;

   print << "END";
usage:

   $prog joblist.txt
   
description:

   To prepare to run a list of autosys jobs in a file:
      validate job's existence.
      print the current job status.
      spot jobs in OH (on-hold), OI (on-ice), or RU (running).
      spot jobs that have downstream dependency.

   -x  ExcludePattern  perl regex pattern, exclude job matched this pattern, case insensitive

   -m  MatchPattern    perl regex pattern, only run job matching this pattern, case insensitive

   -u UnivPatterns      use this to check dependent jobs, when '-chkdep' specified

   -de n               expire Detail cache after n seconds. default $DetailExpire.

   -se n               expire Status cache after n seconds. default $StatusExpire.

   -df DetailFiles     Use DetailFiles instead. multiple filenames separated by coma.

   -sf StatusFiles     Use StatusFiles instead. multiple filenames separated by coma.

   If '-u UnivPatterns' is not set, this script will first search \$UNIV_PATTERNS in
   shell environment.

   If \$UNIV_PATTERNS is not set in environment, this script will search it in
   ~/.tpautosys, a bash init file.

examples:

   $prog abatch_test.txt

   - test without autosys
   $prog -df adep_autorep_J_q_example.txt -sf adep_autorep_J_example.txt abatch_test.txt

END

   exit 1;
}

my $verbose;
my $MatchPattern;
my $ExcludePattern;
my $DetailFiles;
my $StatusFiles;
my $UnivPatterns;

GetOptions(
   'v|verbose'     => \$verbose,
   'm=s'           => \$MatchPattern,
   'x=s'           => \$ExcludePattern,
   'u=s'           => \$UnivPatterns,
   'df=s'          => \$DetailFiles,
   'sf=s'          => \$StatusFiles,
   'de=s'          => \$DetailExpire,
   'se=s'          => \$StatusExpire,
) || usage("cannot parse command line: $!");

usage("wrong number of args") if @ARGV != 1;

my ($file) = @ARGV;

my @jobs;
my $seen;

my $ifh = get_in_fh($file);

while (<$ifh>) {
   chomp $_;
   my $job = $_;

   next if $job =~ /^\s*$/;     # skip blank lines
   next if $job =~ /^\s*#/;     # skip comment

   next if defined   $MatchPattern && $job !~   /$MatchPattern/i; 

   push @jobs, $job;
   $seen->{$job} ++;
}

close $ifh;

my $opt = {
   UnivPatterns=>$UnivPatterns,
   DetailExpire=>$DetailExpire,
   StatusExpire=>$StatusExpire,
   DetailFiles=>$DetailFiles,
   StatusFiles=>$StatusFiles,
};

my $info = query_jobs($opt);

my $exists_box_job;

for my $job (keys %$info) {
   my $box_name = $info->{box_name};

   if ($box_name) {
      $exists_box_job->{$box_name}->{$job} ++;
   }
}

my $error = 0;

for my $job (@jobs) {
   print "\n";

   if (!$info->{$job}) {
      print "$job: not found\n";
      $error ++;
      next;
   }

   if (!$info->{$job}->{Status}) {
      print "$job: status not found. just deleted?\n";
      $error ++;
      next;
   }

   print "$job $info->{$job}->{LastStart} $info->{$job}->{LastEnd} $info->{$job}->{Status}\n";

   if ($info->{$job}->{Status} =~ /^(OH|OI|RU)$/) {
      print "   $job is in $info->{$job}->{Status} mode.\n";
      $error ++;
      next;
   }

   my @conditionals;

   my $dependency = get_dependency($job, {%$opt, DepExps=>['$Status !~ /OH|OI/']});

   if ($dependency->{down}) {
      for my $dep (@{$dependency->{down}}) {
         if ($dep->{reason} ne 'box_child') {
            push @conditionals, $dep->{detail}->{JobName};
         }
      }
   }
    
   if (@conditionals) {
      print "   $job has conditioanl dependencies: ", join(" ", @conditionals);
      $error ++;
      next;
   }
}

print "Total $error errors\n";

exit $error;
