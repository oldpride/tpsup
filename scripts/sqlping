#!/bin/bash

usage () {
   cat >&2 <<EOF
usage:

   $0 db_nickname
   $0 all


example:

   $0 a@b

EOF

   exit 1
}

if [ $# -eq 0 ]; then
   echo "wrong number of args" >&2
   usage
fi

error=0

if [ $1 = all ]; then
   pinglist=`sed 1d ~/.tpsup/conn.csv|cut -d, -f1|sed -e 's:^[ ][ ]*::'|grep ^[a-zA-Z0-9@]`
else
   pinglist="$@"
fi

for nickname in $pinglist
do 
   echo "" >&2
   echo "INFO: pinging $nickname" >&2
   if ! timeout 5 sql -noheader $nickname "select '$nickname: success'"; then
      echo "$nickname: failure"
      ((error++))
   fi
done

exit $error

