#!/usr/bin/env perl

use warnings;
use strict;
use Data::Dumper;
use Getopt::Long;
use Carp;
use TPSUP::AUTOSYS qw(get_dependency query_jobs print_autorep_J_header
                      get_autorep_J_format autorep_J);
use TPSUP::UTIL    qw(get_in_fh);
# use Carp::Always;

my $prog = $0; $prog =~ s:.*/::;

my $DetailExpire = 300;
my $StatusExpire = 1;

sub usage {
   my ($message) = @_;
   print "$message\n" if $message;

   print << "END";
usage:

   $prog [-q] joblist.txt
   
description:

   Run autorep for jobs listed in a file, joblist.txt. Within the file, one job per line.
   The file allows comments (#) and blank lines.

   -x  ExcludePattern  perl regex pattern, exclude job matched this pattern, case insensitive

   -m  MatchPattern    perl regex pattern, only run job matching this pattern, case insensitive

   -u UnivPatterns     use this to check dependent jobs, when '-chkdep' specified

   -de n               expire Detail cache after n seconds. default $DetailExpire.

   -se n               expire Status cache after n seconds. default $StatusExpire.

   -df DetailFiles     Use DetailFiles instead. multiple filenames separated by coma.

   -sf StatusFiles     Use StatusFiles instead. multiple filenames separated by coma.

   -f                  force to run the jobs without prompt for confirmation.

   -n                  dryrun mode, check-only. will print the command but won't run the jobs.

   If '-u UnivPatterns' is not set, this script will first search \$UNIV_PATTERNS in
   shell environment.

   If \$UNIV_PATTERNS is not set in environment, this script will search it in
   ~/.tpautosys, a bash init file.

examples:

   $prog abatch_test.txt

   - test without autosys
   $prog    -df adep_autorep_J_q_example.txt -sf adep_autorep_J_example.txt abatch_test_fatal.txt
   $prog -q -df adep_autorep_J_q_example.txt -sf adep_autorep_J_example.txt abatch_test_good.txt

END

   exit 1;
}

my $verbose;
my $MatchPattern;
my $ExcludePattern;
my $DetailFiles;
my $StatusFiles;
my $UnivPatterns;
my $detail;

GetOptions(
   'v|verbose'     => \$verbose,
   'q'             => \$detail,
   'm=s'           => \$MatchPattern,
   'x=s'           => \$ExcludePattern,
   'u=s'           => \$UnivPatterns,
   'df=s'          => \$DetailFiles,
   'sf=s'          => \$StatusFiles,
   'de=s'          => \$DetailExpire,
   'se=s'          => \$StatusExpire,
) || usage("cannot parse command line: $!");

usage("wrong number of args") if @ARGV != 1;

my ($file) = @ARGV;

my @jobs;
my $seen;

my $ifh = get_in_fh($file);

while (<$ifh>) {
   chomp $_;
   my $job = $_;

   next if $job =~ /^\s*$/;     # skip blank lines
   next if $job =~ /^\s*#/;     # skip comment

   $job =~ s/^\s+//;     # trim spaces
   $job =~ s/\s+$//;     # trim spaces

   next if defined   $MatchPattern && $job !~   /$MatchPattern/i; 
   next if defined $ExcludePattern && $job =~ /$ExcludePattern/i; 

   push @jobs, $job;
   $seen->{$job} ++;
}

close $ifh;

my $opt = {
   UnivPatterns => $UnivPatterns,
   DetailExpire => $DetailExpire,
   StatusExpire => $StatusExpire,
   DetailFiles  => $DetailFiles,
   StatusFiles  => $StatusFiles,
};

my $info = query_jobs($opt);

my $exists_box_job;

for my $job (keys %$info) {
   my $box_name = $info->{box_name};

   if ($box_name) {
      $exists_box_job->{$box_name}->{$job} ++;
   }
}

if (!$detail) {
   print_autorep_J_header();

   for my $job (@jobs) {
      if (!$info->{$job}) {
         printf get_autorep_J_format(), $job,  "not found", "", "";
      } else {
         printf get_autorep_J_format(),
            $job, $info->{$job}->{LastStart}, $info->{$job}->{LastEnd}, $info->{$job}->{Status};
      }
   }
} else {
   for my $job (@jobs) {
      if (!$info->{$job}) {
         printf  "$job not found\n";
      } else {
         for my $attr (sort keys(%{$info->{$job}})) {
            printf  "$attr: $info->{$job}->{$attr}\n";
         }
      }
      print "\n";
   }  
}

exit 0;
