#!/usr/bin/env perl

use warnings;
use strict;
use Data::Dumper;
use Getopt::Long;
use Carp;
use TPSUP::AUTOSYS qw(get_dependency query_jobs);
use TPSUP::UTIL    qw(get_in_fh);
# use Carp::Always;

my $prog = $0; $prog =~ s:.*/::;

my $DetailExpire = 300;
my $StatusExpire = 1;

sub usage {
   my ($message) = @_;
   print "$message\n" if $message;

   print << "END";
usage:

   $prog joblist.txt
   
description:

   run a list of autosys jobs, stored in a file

   -x  ExcludePattern  perl regex pattern, exclude job matched this pattern, case insensitive

   -m  MatchPattern    perl regex pattern, only run job matching this pattern, case insensitive

   -ignoreDep          check dependent jobs, so that we won't trigger dependent
                       jobs by mistake

   -u UnivPatterns     use this to check dependent jobs, when '-ignoreDep' specified

   -n                  dry-run

   -v                  verbose

   -de n               expire Detail cache after n seconds. default $DetailExpire.

   -se n               expire Status cache after n seconds. default $StatusExpire.

   If '-u UnivPatterns' is not set, this script will first search \$UNIV_PATTERNS in
   shell environment.

   If \$UNIV_PATTERNS is not set in environment, this script will search it in
   ~/.tpautosys, a bash init file.

examples:

   $prog               abatch_test.txt

   $prog -n -ignoreDep abatch_test.txt

   - test without autosys
   $prog -df adep_autorep_J_q_example.txt -sf adep_autorep_J_example.txt abatch_test.txt

END

   exit 1;
}

my $verbose;
my $MatchPattern;
my $ExcludePattern;
my $dryrun;
my $ignoreDep;
my $DetailFiles;
my $StatusFiles;
my $UnivPatterns;

GetOptions(
   'v|verbose'     => \$verbose,
   'm=s'           => \$MatchPattern,
   'x=s'           => \$ExcludePattern,
   'n|dryrun'      => \$dryrun,
   'ignoreDep'     => \$ignoreDep,
   'u=s'           => \$UnivPatterns,
   'df=s'          => \$DetailFiles,
   'sf=s'          => \$StatusFiles,
   'de=s'          => \$DetailExpire,
   'se=s'          => \$StatusExpire,
) || usage("cannot parse command line: $!");

usage("wrong number of args") if @ARGV != 1;

my ($file) = @ARGV;

my @jobs;
my $seen;

my $ifh = get_in_fh($file);

while (<$ifh>) {
   chomp $_;
   my $job = $_;

   next if $job =~ /^\s*$/;     # skip blank lines
   next if $job =~ /^\s*#/;     # skip comment

   next if defined $MatchPattern && $job !~ /$MatchPattern/i; 

   push @jobs, $job;
   $seen->{$job} ++;
}

close $ifh;

my $opt = {
   UnivPatterns=>$UnivPatterns,
   DetailExpire=>$DetailExpire,
   StatusExpire=>$StatusExpire,
   DetailFiles=>$DetailFiles,
   StatusFiles=>$StatusFiles,
};

my $info = query_jobs($opt);

my $exists_box_job;

for my $job (keys %$info) {
   my $box_name = $info->{$job}->{box_name};

   if ($box_name) {
      $exists_box_job->{$box_name}->{$job} ++;
   }
}

my $subjobs_by_job;

for my $job (@jobs) {
   print "$job = ", Dumper($info->{$job});

   if (!$info->{$job}) {
      print "ERROR: cannot find $job\n";
      if ($dryrun) {
         next;
      } else {
         exit 1;
      }
         
   }

   if (!$info->{$job}->{Status}) {
      print "ERROR: $job missing Status\n";
      if (!$dryrun) {
         exit 1;
      }
   } elsif ($info->{$job}->{Status} = /OH|OI/) {
      
   }

   if (!$ignoreDep) {
      my $dependency = get_dependency($job, {%$opt, DepExps=>['$Status !~ /OH|OI/']});

      if ($dependency->{down}) {
         # if the job is box and the dependency is box_child, ignore
         for my $dep (@{$dependency->{down}}) {
            if ($dep->{reason} ne 'box_child') {
               print STDERR "$job has dependent $dep->{detail}->{JobName}\n";
               exit 1;
            }
         }
      }
   }

   if (!$info->{$job}->{job_type}) {
      print "ERROR: missing Detail of $job, eg, job_type\n";
      if (!$dryrun) {
         exit 1;
      }
   } elsif ($info->{$job}->{job_type} eq 'BOX') {
      # print  "\$exists_box_job->{$job}) = ", Dumper($exists_box_job->{$job});

      for my $j2 (keys %{$exists_box_job->{$job}}) {
         if ( $info->{$j2}->{Status} !~ /^(OH|OI)$/ ) {
            push @{$subjobs_by_job->{$job}}, $j2;
         } 
      }

      if (!$subjobs_by_job->{$job}) {
         print "ERROR: all jobs in BOX $job are OH or OI\n";
         if (!$dryrun) {
            exit 1;
         }
      }

      my @runners;

      for my $j2 (keys %{$exists_box_job->{$job}}) {
         if ( $info->{$j2}->{Status} eq 'RU' ) {
            push @runners, $j2;
         } 
      }

      if (@runners) {
         print "ERROR: some jobs in BOX $job are RU: ", join(' ', @runners), "\n";
         if (!$dryrun) {
            exit 1;
         }
      }


   } else {
      push @{$subjobs_by_job->{$job}}, $job;
   }
}

for my $job (@jobs) {
   { 
      my $cmd = "sendevent -E FORCE_STARTJOB -J $job";
   
      print "cmd = $cmd\n";
      if (!$dryrun) {
         system($cmd);
         $? && exit 1;
      }
   }
   
   while (1) { 
      my $cmd = "autorep -J $job";
   
      print "cmd = $cmd\n";

      if (!$dryrun) {
         my @lines = `$cmd`;
         $? && exit 1;

         my @failed = grep {/ (TE|FA) /} @lines;

         if (@failed) {
            print "$job failed\n"; 
            print @lines;
            exit 1;
         }

         my @successful = grep {/ (SU) /} @lines;

         print "$job: ", scalar(@successful), " of ", scalar(@{$subjobs_by_job->{$job}}), " succeeded\n";

         if (scalar(@successful) == scalar(@{$subjobs_by_job->{$job}})) {
            last;
         }
      }

      last if $dryrun;

      sleep 10;
   }
}

print "all complete successfully\n";

exit 0;
