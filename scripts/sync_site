#!/bin/bash

depot_dir=~/depot
site_dir=~/github

usage () {
   cat <<EOF
usage:

   $0 check
   $0 diff         # check and then diff
   $0 sync

   -d depot_dir     where you should see <depot_dir>/tpsup. 
                    default to $depot_dir. 

   -s site_dir      where you should see  <site_dir>/tpsup.
                    dfault to $site_dir

example:

EOF

   exit 1
}

verbose=N

while getopts vs:d: o;
do
   case "$o" in
      d) depot_dir="$OPTARG";;
      s)  site_dir="$OPTARG";;
      v) verbose=Y;;
      *) echo "unknow switch '$o'"; usage;;
   esac
done

shift $((OPTIND-1))

if [ $# -ne 1 ]; then
   echo "wrong number of args"
   usage
fi

action=$1

cd $depot_dir/tpsup || exit 1
git pull 

if [ $action = check -o $action = diff ]; then
   flag="-n"
elif [ $action = sync ]; then
   flag=""
else
   echo "unknown action='$action'"
   usage
fi

# --existing           only to update existing files
# --exclude='*[.]site' to skips site-specific files
# --exclude='[.]git*'  to skip .git/ and .gitignore
# -i                   to print item to be changed
files=`(set -x;rsync $flag -a -i --existing --exclude='[.]git*' --exclude='.nfs*' --exclude='.sw*' --exclude='[.]idea' --exclude=__pychche__ --exclude='*[.]site' $depot_dir/tpsup $site_dir/)`

echo "$files"

if [ $action = diff ]; then
   # skip dir
   for f in `echo "$files" |awk '{print $2}'|egrep -v '/$'`
   do
      echo ""
      (set -x; diff $depot_dir/$f $site_dir/$f)
   done
fi


